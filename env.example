# === HellBurn Deployment Config (v2 post-audit) ===

# RPC URLs (kostenlosen Key bei alchemy.com oder infura.io holen)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/DEIN_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/DEIN_KEY

# Deployer Wallet Private Key (NIEMALS committen!)
DEPLOYER_KEY=0x_DEIN_PRIVATE_KEY

# Etherscan API Key für Contract-Verifizierung
ETHERSCAN_API_KEY=DEIN_ETHERSCAN_KEY

# === NEU in v2: Rollen ===
# Guardian: Kann Emergency-Pause auslösen. Idealerweise ein Gnosis Safe Multisig.
GUARDIAN_ADDRESS=0x_DEINE_MULTISIG_ADRESSE

# Genesis-Empfänger: Bekommt 8% der gebrannten TitanX
GENESIS_RECIPIENT=0x_DEINE_ADRESSE

# DragonX Vault: Bekommt 35% der TitanX zum DragonX-Kauf
DRAGONX_VAULT=0x_DRAGONX_VAULT_ADRESSE

# === Mainnet Adressen (nicht ändern) ===
TITANX_ADDRESS=0xf19308f923582a6f7c465e5ce7a9dc1bec6665b1
DRAGONX_ADDRESS=0x96a5399D07896f757Bd4c6eF56461F58DB951862
